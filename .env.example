# Obsidian Local REST API（仅 --save-obsidian 用法需要）
OBSIDIAN_API_KEY=
OBSIDIAN_HOST=127.0.0.1
OBSIDIAN_PORT=27123
VAULT_PREFIX=WeChat/

# AI（摘要分类 + Whisper 转录）。优先读环境变量 OPENAI_API_KEY，可在此覆盖
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
WHISPER_MODEL=whisper-1

# 公众号抓取限速（秒）
WX_MIN_DELAY=15
WX_MAX_DELAY=40

# 视频关键帧：每多少秒抽 1 帧 / 最多抽几帧
FRAME_INTERVAL_SEC=4
FRAME_MAX=40
